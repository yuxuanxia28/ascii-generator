<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ASCII Cat Animator</title>
    <style>
        body {
            background-color: #050505;
            color: #00FF41; /* Classic Matrix Green */
            font-family: 'Courier New', Courier, monospace;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            overflow: hidden;
        }

        .controls {
            text-align: center;
            margin-bottom: 20px;
            z-index: 10;
        }

        h1 {
            margin: 0 0 10px 0;
            font-size: 1.5rem;
            text-shadow: 0 0 8px rgba(0, 255, 65, 0.6);
        }

        p {
            font-size: 0.9rem;
            color: #a0a0a0;
            max-width: 400px;
            margin: 0 auto 15px auto;
        }

        .btn {
            background-color: #00FF41;
            color: #050505;
            padding: 8px 16px;
            cursor: pointer;
            font-weight: bold;
            border-radius: 4px;
            transition: all 0.2s;
            display: inline-block;
        }

        .btn:hover {
            background-color: #00cc33;
            box-shadow: 0 0 10px rgba(0, 255, 65, 0.5);
        }

        #ascii-container {
            /* Keeps the text responsive to the screen size */
            font-size: clamp(6px, 1.2vw, 14px);
            line-height: 1;
            letter-spacing: 0;
            white-space: pre;
            user-select: none;
            text-shadow: 0 0 4px rgba(0, 255, 65, 0.4);
        }
    </style>
</head>
<body>

    <div class="controls">
        <h1>ASCII Cat Animator</h1>
        <p>Playing default animation. Upload your specific video reference to map it to real-time ASCII!</p>
        <label class="btn">
            Upload Reference Video
            <input type="file" id="video-upload" accept="video/*" style="display:none;">
        </label>
    </div>

    <div id="ascii-container"></div>

    <script>
        const fileInput = document.getElementById('video-upload');
        const container = document.getElementById('ascii-container');
        
        // Setup hidden canvas and video elements for processing
        const video = document.createElement('video');
        video.loop = true;
        video.muted = true;
        video.playsInline = true;

        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d', { willReadFrequently: true });
        
        // ASCII Map: "@" is the densest (for black shadows), " " is empty space (for white background)
        const charMap = "@%#*+=-:. "; 

        let isPlayingVideo = false;
        let fallbackInterval;

        // ----------------------------------------------------
        // FALLBACK: Hand-crafted ASCII walk cycle
        // ----------------------------------------------------
        const catFrames = [
String.raw`
       /\__         _ 
      /    \_      ( \
     |       \______) )
     |                |
    / /  \ \     \ \  / /
   /_/    \_\    /_/  \_\
`,
String.raw`
       /\__         _ 
      /    \_      ( \
     |       \______) )
     |                |
    | |    | |   | |    | |
    |_|    |_|   |_|    |_|
`,
String.raw`
       /\__         _ 
      /    \_      ( \
     |       \______) )
     |                |
    \ \  / /     / /  \ \
    /_/  \_\    /_/    \_\
`,
String.raw`
       /\__         _ 
      /    \_      ( \
     |       \______) )
     |                |
    | |    | |   | |    | |
    |_|    |_|   |_|    |_|
`
        ];

        function startFallback() {
            let frameIdx = 0;
            // Pad the smaller hand-drawn ASCII to keep it centered
            fallbackInterval = setInterval(() => {
                container.textContent = "\n\n\n\n\n\n" + catFrames[frameIdx];
                frameIdx = (frameIdx + 1) % catFrames.length;
            }, 180); // 180ms per frame
        }

        // ----------------------------------------------------
        // VIDEO TO ASCII CONVERTER: Uses the uploaded reference
        // ----------------------------------------------------
        fileInput.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (!file) return;
            
            // Stop the hand-drawn animation
            clearInterval(fallbackInterval);
            isPlayingVideo = true;

            // Load video into the hidden element
            const url = URL.createObjectURL(file);
            video.src = url;
            video.play();
        });

        // Wait for metadata to load so video dimensions are available
        video.addEventListener('loadedmetadata', () => {
            // Setup canvas dimensions based on aspect ratio
            const targetCols = 100; // Resolution of ASCII characters wide
            const videoAspect = video.videoHeight / video.videoWidth;
            // Monospace characters are taller than they are wide. ~0.6 compensates for this.
            const charAspect = 0.6; 
            
            canvas.width = targetCols;
            // Ensure height is at least 1 to prevent IndexSizeError
            canvas.height = Math.max(1, Math.floor(targetCols * videoAspect * charAspect));
        });

        video.addEventListener('play', () => {
            // Start rendering loop
            drawFrame();
        });

        function drawFrame() {
            if (!isPlayingVideo || video.paused || video.ended) return;

            // Prevent IndexSizeError if metadata is still loading and height is 0
            if (canvas.width === 0 || canvas.height === 0) {
                requestAnimationFrame(drawFrame);
                return;
            }

            // Draw current video frame to hidden canvas
            ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
            const imgData = ctx.getImageData(0, 0, canvas.width, canvas.height);
            const data = imgData.data;

            let asciiStr = "";
            for (let y = 0; y < canvas.height; y++) {
                for (let x = 0; x < canvas.width; x++) {
                    const offset = (y * canvas.width + x) * 4;
                    const r = data[offset];
                    const g = data[offset + 1];
                    const b = data[offset + 2];
                    
                    // Calculate pixel luminance (Standard gray-scale formula)
                    const brightness = (0.299 * r + 0.587 * g + 0.114 * b);
                    
                    // Map brightness (0 = black, 255 = white) to character array
                    const charIdx = Math.floor((brightness / 255) * (charMap.length - 1));
                    
                    asciiStr += charMap[charIdx];
                }
                asciiStr += "\n"; // Next row
            }
            
            // Update the DOM
            container.textContent = asciiStr;
            
            // Request next frame
            requestAnimationFrame(drawFrame);
        }

        // Initialize with default walk cycle
        startFallback();
    </script>
</body>
</html>
